        "verify",
        "python tooling",
        "python-best-practices"
      ]
    },
    {
      "name": "mature-automation-repo-preservation",
      "fixture": "evals/fixtures/mature-automation-repo",
      "prompt": "Review this mature automation repository as an existing Python-supporting project. Inspect its conventions first, preserve its native gate, and recommend only safe incremental Python improvements without migrating the project structure or tooling.",
      "should_trigger": true,
      "expected_references": [
        "mature-repo-preservation.md",
        "project-orientation.md",
        "review-checklist.md"
      ],
      "must_include": [
        "AGENTS.md",
        "preserve",
        "native gate",
        "bash scripts/check-consistency.sh",
        "python3 -m pytest tests -q"
      ],
      "must_not_include": [
        "force uv",
        "force src layout",
        "replace the native gate",
        "convert to a package"
      ],
      "must_include_any": [
        {
          "name": "modernization stays optional and scoped",
          "terms": [
            "safe incremental",
            "do not add `pyproject.toml`",
            "unless the repository\u2019s role changes",
            "unless the repository's role changes",
            "not a packaged application",
            "not a package"
          ]
        }
      ]
    }
  ]
}
