      ]
    },
    {
      "name": "shell-script-question",
      "fixture": "evals/fixtures/greenfield-empty",
      "prompt": "How do I write a for loop over files in bash?",
      "should_trigger": false,
      "expected_references": [],
      "must_include": [],
      "must_not_include": [
        "ruff",
