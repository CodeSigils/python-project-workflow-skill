        "python-best-practices skill",
        "ruff",
        "mypy",
        "code review",
        "skill scaffolding",
        "skill triggered",
        "trigger assessment"
      ]
    },
    {
      "name": "generic-python-question",
      "fixture": "evals/fixtures/greenfield-empty",
      "prompt": "What's the difference between lists and tuples in Python?",
      "should_trigger": false,
      "expected_references": [],
      "must_include": [],
      "must_not_include": [
        "inspect repository",
        "verification commands",
        "ruff",
        "pytest"
      ]
    },
    {
      "name": "typo-in-docstring",
      "fixture": "evals/fixtures/existing-preserve",
      "prompt": "I noticed a typo in the docstring for `greet` \u2014 can you fix it?",
      "should_trigger": false,
      "expected_references": [],
      "must_include": [],
